# Copy this file to ".env" and fill in real values. NEVER commit your .env.
# In development, python-dotenv loads this automatically when you run run_scan.py.

# --- AI pass (optional) ------------------------------------------------------
# The scanner's rules pass always runs with NO key. The AI pass — for the subtle,
# unlabelled identifiers — needs this. Without it, the scanner runs rules-only and
# reports ai_status="failed". That is by design: a scan must never crash.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Synthetic generator keys (optional) -------------------------------------
# These mirror the Session 11 app. If unset, synthetic/crypto.py uses the same
# dev-safe fallbacks, so the generator runs out of the box. In production the AI
# Office reads these from a managed key vault, never from a file.
FERNET_KEY=
OPTIMUS_RANDOM=
